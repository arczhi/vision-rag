# =====================================================================
# vision-rag 环境变量模板 (此文件可提交 git, 不含真实秘钥)
# 使用方法: cp .env.example .env  并填入真实凭证
# =====================================================================

# ---- 阿里云 DashScope (Qwen-VL 视频推理 + 高光命名 LLM) ----
# 申请: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URI=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_SEGMENT_MODEL=qwen3.5-plus

# ---- 火山引擎 TOS 对象存储 (上传视频供 Qwen-VL 拉取) ----
# 控制台: https://console.volcengine.com/tos/
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_BUCKET=your-bucket-name
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_PUBLIC_DOMAIN=https://your-cdn-domain.com/
TOS_MAIN_PATH=your/object/prefix

# ---- 字节跳动 MediaKit (备选高光提取) ----
# 控制台: https://console.volcengine.com/mediakit/
BYTEDANCE_MEDIAKIT_TOKEN=

# ---- Qdrant (主视频多模态 named-vector 索引) ----
# Docker/native 本地默认: http://localhost:6333/dashboard
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=highlight_clips
QDRANT_VECTOR_BUSINESS=highlight
QDRANT_ENABLE_VLM_CAPTION=1

# ---- 模型 / 设备运行时 (可选，覆盖 config.py 默认) ----
# EMBEDDING_BACKEND=cn_clip
# EMBEDDING_MODEL=OFA-Sys/chinese-clip-vit-large-patch14-336px
# EMBEDDING_DIM=768
# EMBEDDING_DEVICE=mps
# EMBEDDING_PRECISION=fp32

# ---- 本地 ASR (faster-whisper, 给 Qwen2-VL 补充台词理解) ----
# 先安装 requirements.txt 中的 faster-whisper，再打开这个开关。
# LOCAL_ASR_MODEL 可以是 faster-whisper 模型名，也可以是本地 snapshot 路径。
ENABLE_LOCAL_ASR=0
LOCAL_ASR_MODEL=small
LOCAL_ASR_DEVICE=cpu
LOCAL_ASR_COMPUTE_TYPE=int8
LOCAL_ASR_LANGUAGE=zh
